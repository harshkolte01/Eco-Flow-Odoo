// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductVersionStatus {
  draft
  active
  archived
}

enum BomVersionStatus {
  draft
  active
  archived
}

enum EcoType {
  product
  bom
}

enum EcoStatus {
  draft
  in_progress
  approved
  applied
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum ActivationEntityType {
  product
  bom
}

enum AuditEntityType {
  product
  bom
  eco
}

enum ApprovalCategory {
  required
  optional
}

enum RuleType {
  stage_rule
  condition_rule
}

enum RuleOperator {
  GT
  LT
  EQ
  GTE
  LTE
  IN
  NOT_IN
  CONTAINS
  NOT_CONTAINS
}

enum DelegationStatus {
  active
  revoked
  expired
}

enum RuleAuditAction {
  created
  updated
  archived
  condition_added
  condition_updated
  condition_deleted
  approver_added
  approver_removed
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model User {
  id           Int       @id @default(autoincrement())
  loginId      String    @unique
  name         String
  email        String    @unique
  passwordHash String
  roleId       Int
  role         Role      @relation(fields: [roleId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  products     Product[]
  ecosRaised   Eco[]     @relation("EcoRaisedBy")
  approvals    EcoApproval[]
  auditLogs    AuditLog[]
  stageApprovers StageApprover[]
  ecoApproverAssignments EcoApproverAssignment[]
  
  // Rule management
  createdRules          ApprovalRule[]     @relation("RuleCreator")
  updatedRules          ApprovalRule[]     @relation("RuleUpdater")
  
  // Delegations
  delegationsFrom       ApproverDelegation[] @relation("DelegationFrom")
  delegationsTo         ApproverDelegation[] @relation("DelegationTo")
  delegationCreations   ApproverDelegation[] @relation("DelegationCreator")
  
  // Rule approver assignments
  ruleApprovers         RuleApprover[]     @relation("RuleApprovers")
  escalationTargets     RuleApprover[]     @relation("EscalationTarget")
  
  // Rule audits
  ruleAudits            RuleAudit[]        @relation("RuleAudits")
  
  // Password reset
  passwordResetTokens   PasswordResetToken[]
  lastPasswordChangeAt  DateTime?
}

model Product {
  id           Int              @id @default(autoincrement())
  productCode  String           @unique
  createdById  Int?
  createdBy    User?            @relation(fields: [createdById], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  versions     ProductVersion[]
  bom          Bom?
  ecos         Eco[]
}

model ProductVersion {
  id               Int                   @id @default(autoincrement())
  productId        Int
  product          Product               @relation(fields: [productId], references: [id])
  versionNo        Int
  productName      String
  salePrice        Decimal?              @db.Decimal(12, 2)
  costPrice        Decimal?              @db.Decimal(12, 2)
  attachments      Json?
  status           ProductVersionStatus
  createdFromEcoId Int?
  createdFromEco   Eco?                  @relation("ProductVersionCreatedFromEco", fields: [createdFromEcoId], references: [id])
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  bomVersions      BomVersion[]
  bomComponents    BomComponent[]        @relation("BomComponentProductVersion")
  ecoProductChanges EcoProductChange[]
  ecoBomComponents EcoBomComponent[]     @relation("EcoBomComponentProductVersion")
  oldActivationLogs VersionActivationLog[] @relation("OldProductVersion")
  newActivationLogs VersionActivationLog[] @relation("NewProductVersion")

  @@unique([productId, versionNo])
}

model Bom {
  id        Int          @id @default(autoincrement())
  productId Int          @unique
  product   Product      @relation(fields: [productId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  versions  BomVersion[]
  ecos      Eco[]
}

model BomVersion {
  id               Int                @id @default(autoincrement())
  bomId            Int
  bom              Bom                @relation(fields: [bomId], references: [id])
  productVersionId Int
  productVersion   ProductVersion     @relation(fields: [productVersionId], references: [id])
  versionNo        Int
  status           BomVersionStatus
  createdFromEcoId Int?
  createdFromEco   Eco?               @relation("BomVersionCreatedFromEco", fields: [createdFromEcoId], references: [id])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  components       BomComponent[]
  operations       BomOperation[]
  ecoBomDrafts     EcoBomDraft[]
  oldActivationLogs VersionActivationLog[] @relation("OldBomVersion")
  newActivationLogs VersionActivationLog[] @relation("NewBomVersion")

  @@unique([bomId, versionNo])
}

model BomComponent {
  id                        Int            @id @default(autoincrement())
  bomVersionId              Int
  bomVersion                BomVersion     @relation(fields: [bomVersionId], references: [id])
  componentProductVersionId Int
  componentProductVersion   ProductVersion @relation("BomComponentProductVersion", fields: [componentProductVersionId], references: [id])
  quantity                  Decimal        @db.Decimal(12, 4)

  @@index([bomVersionId])
  @@index([componentProductVersionId])
}

model BomOperation {
  id           Int        @id @default(autoincrement())
  bomVersionId Int
  bomVersion   BomVersion @relation(fields: [bomVersionId], references: [id])
  operationName String
  timeMinutes  Int
  workCenter   String?

  @@index([bomVersionId])
}

model EcoStage {
  id               Int              @id @default(autoincrement())
  name             String           @unique
  sequenceOrder    Int
  approvalRequired Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  ecos             Eco[]
  approvals        EcoApproval[]
  stageApprovers   StageApprover[]
  approverAssignments EcoApproverAssignment[]
}

model Eco {
  id             Int                 @id @default(autoincrement())
  title          String
  ecoType        EcoType
  productId      Int
  product        Product             @relation(fields: [productId], references: [id])
  bomId          Int?
  bom            Bom?                @relation(fields: [bomId], references: [id])
  raisedById     Int
  raisedBy       User                @relation("EcoRaisedBy", fields: [raisedById], references: [id])
  effectiveDate  DateTime?
  versionUpdate  Boolean             @default(true)
  currentStageId Int
  currentStage   EcoStage            @relation(fields: [currentStageId], references: [id])
  status         EcoStatus
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  approvals      EcoApproval[]
  approverAssignments EcoApproverAssignment[]
  productChange  EcoProductChange?
  bomDraft       EcoBomDraft?
  createdProductVersions ProductVersion[] @relation("ProductVersionCreatedFromEco")
  createdBomVersions BomVersion[]    @relation("BomVersionCreatedFromEco")
  activationLogs VersionActivationLog[]
  ruleEvaluations RuleEvaluationLog[] @relation("RuleEvaluations")

  @@index([productId])
  @@index([bomId])
  @@index([raisedById])
  @@index([currentStageId])
}

model EcoApproval {
  id         Int            @id @default(autoincrement())
  ecoId      Int
  eco        Eco            @relation(fields: [ecoId], references: [id])
  stageId    Int
  stage      EcoStage       @relation(fields: [stageId], references: [id])
  approverId Int
  approver   User           @relation(fields: [approverId], references: [id])
  status     ApprovalStatus
  actionDate DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([ecoId, stageId])
  @@index([approverId])
}

model EcoApproverAssignment {
  id               Int              @id @default(autoincrement())
  ecoId            Int
  eco              Eco              @relation(fields: [ecoId], references: [id])
  stageId          Int
  stage            EcoStage         @relation(fields: [stageId], references: [id])
  userId           Int
  user             User             @relation(fields: [userId], references: [id])
  approvalCategory ApprovalCategory @default(required)
  ruleId           String?
  source           String           @default("rule")
  createdAt        DateTime         @default(now())

  @@unique([ecoId, stageId, userId])
  @@index([ecoId, stageId])
  @@index([stageId])
  @@index([userId])
}

model EcoProductChange {
  id                   Int            @id @default(autoincrement())
  ecoId                Int            @unique
  eco                  Eco            @relation(fields: [ecoId], references: [id])
  baseProductVersionId Int
  baseProductVersion   ProductVersion @relation(fields: [baseProductVersionId], references: [id])
  newProductName       String?
  newSalePrice         Decimal?       @db.Decimal(12, 2)
  newCostPrice         Decimal?       @db.Decimal(12, 2)
  newAttachments       Json?

  @@index([ecoId])
  @@index([baseProductVersionId])
}

model EcoBomDraft {
  id               Int        @id @default(autoincrement())
  ecoId            Int        @unique
  eco              Eco        @relation(fields: [ecoId], references: [id])
  baseBomVersionId Int
  baseBomVersion   BomVersion @relation(fields: [baseBomVersionId], references: [id])
  components       EcoBomComponent[]
  operations       EcoBomOperation[]

  @@index([ecoId])
  @@index([baseBomVersionId])
}

model EcoBomComponent {
  id                        Int            @id @default(autoincrement())
  ecoBomDraftId             Int
  ecoBomDraft               EcoBomDraft    @relation(fields: [ecoBomDraftId], references: [id])
  componentProductVersionId Int
  componentProductVersion   ProductVersion @relation("EcoBomComponentProductVersion", fields: [componentProductVersionId], references: [id])
  quantity                  Decimal        @db.Decimal(12, 4)

  @@index([ecoBomDraftId])
  @@index([componentProductVersionId])
}

model EcoBomOperation {
  id            Int         @id @default(autoincrement())
  ecoBomDraftId Int
  ecoBomDraft   EcoBomDraft @relation(fields: [ecoBomDraftId], references: [id])
  operationName String
  timeMinutes   Int
  workCenter    String?

  @@index([ecoBomDraftId])
}

model VersionActivationLog {
  id                  Int                 @id @default(autoincrement())
  ecoId               Int
  eco                 Eco                 @relation(fields: [ecoId], references: [id])
  oldProductVersionId Int?
  oldProductVersion   ProductVersion?     @relation("OldProductVersion", fields: [oldProductVersionId], references: [id])
  newProductVersionId Int?
  newProductVersion   ProductVersion?     @relation("NewProductVersion", fields: [newProductVersionId], references: [id])
  oldBomVersionId     Int?
  oldBomVersion       BomVersion?         @relation("OldBomVersion", fields: [oldBomVersionId], references: [id])
  newBomVersionId     Int?
  newBomVersion       BomVersion?         @relation("NewBomVersion", fields: [newBomVersionId], references: [id])
  entityType          ActivationEntityType
  activatedAt         DateTime            @default(now())
}

model AuditLog {
  id            Int            @id @default(autoincrement())
  entityType    AuditEntityType
  entityId      String
  action        String
  oldValue      Json?
  newValue      Json?
  performedById Int
  performedBy   User           @relation(fields: [performedById], references: [id])
  timestamp     DateTime       @default(now())

  @@index([performedById])
  @@index([entityType, entityId])
}

model StageApprover {
  id               Int              @id @default(autoincrement())
  stageId          Int
  stage            EcoStage         @relation(fields: [stageId], references: [id], onDelete: Cascade)
  userId           Int
  user             User             @relation(fields: [userId], references: [id])
  approvalCategory ApprovalCategory @default(required)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([stageId, userId])
  @@index([stageId])
  @@index([userId])
}

// ========== APPROVAL RULES SYSTEM (NEW) ==========

model ApprovalRule {
  id                String            @id @default(cuid())
  name              String            @unique
  description       String?
  ruleType          RuleType          @default(condition_rule)
  isActive          Boolean           @default(true)
  priority          Int               @default(100)
  
  // Relationships
  stageIds          Int[]             // JSON array of stage IDs this rule applies to
  conditions        RuleCondition[]
  approvers         RuleApprover[]
  ruleAudits        RuleAudit[]
  ruleEvaluations   RuleEvaluationLog[]
  
  // Audit fields
  createdById       Int
  createdBy         User              @relation("RuleCreator", fields: [createdById], references: [id])
  createdAt         DateTime          @default(now())
  updatedById       Int?
  updatedBy         User?             @relation("RuleUpdater", fields: [updatedById], references: [id])
  updatedAt         DateTime          @updatedAt
  
  // Versioning
  version           Int               @default(1)
  isArchived        Boolean           @default(false)
  
  @@index([isActive, priority])
  @@index([ruleType])
  @@index([isArchived])
}

model RuleCondition {
  id                String              @id @default(cuid())
  ruleId            String
  rule              ApprovalRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  
  // Condition logic
  fieldName         String              // "product.salePrice", "eco.type", "product.category"
  operator          RuleOperator        // GT, LT, EQ, IN, CONTAINS, etc.
  fieldValue        String              // "1000", "product", "ELECTRONICS"
  logicalOperator   String              @default("AND")  // AND/OR between conditions
  
  createdAt         DateTime            @default(now())
  
  @@index([ruleId])
}

model RuleApprover {
  id                    String                @id @default(cuid())
  ruleId                String
  rule                  ApprovalRule          @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  
  userId                Int
  approver              User                  @relation("RuleApprovers", fields: [userId], references: [id])
  
  approvalCategory      ApprovalCategory      @default(required)
  sequence              Int                   @default(1)
  
  // Delegation support
  canDelegate           Boolean               @default(true)
  escalationUserId      Int?                  // Who to escalate to if this user unavailable
  escalationUser        User?                 @relation("EscalationTarget", fields: [escalationUserId], references: [id])
  escalationThresholdDays Int?                // Escalate after N days
  
  createdAt             DateTime              @default(now())
  
  @@unique([ruleId, userId])
  @@index([ruleId, userId])
}

model RuleAudit {
  id                String            @id @default(cuid())
  ruleId            String?
  rule              ApprovalRule?     @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  action            RuleAuditAction
  
  oldValue          String?           // JSON serialized
  newValue          String?           // JSON serialized
  
  performedById     Int
  performedBy       User              @relation("RuleAudits", fields: [performedById], references: [id])
  performedAt       DateTime          @default(now())
  
  @@index([ruleId])
  @@index([performedAt])
}

model ApproverDelegation {
  id                String            @id @default(cuid())
  fromUserId        Int               // Original approver
  fromUser          User              @relation("DelegationFrom", fields: [fromUserId], references: [id])
  
  toUserId          Int               // Temporary delegate
  toUser            User              @relation("DelegationTo", fields: [toUserId], references: [id])
  
  startDate         DateTime
  endDate           DateTime
  
  reason            String?
  status            DelegationStatus  @default(active)
  
  createdById       Int
  createdBy         User              @relation("DelegationCreator", fields: [createdById], references: [id])
  createdAt         DateTime          @default(now())
  
  @@index([fromUserId, startDate, endDate])
  @@index([toUserId, status])
}

model RuleEvaluationLog {
  id                String            @id @default(cuid())
  ecoId             Int
  eco               Eco               @relation("RuleEvaluations", fields: [ecoId], references: [id])
  
  ruleId            String
  rule              ApprovalRule      @relation(fields: [ruleId], references: [id])
  
  conditionsMet     Boolean
  evaluatedApprovers String           // JSON array of approver IDs
  
  evaluatedAt       DateTime          @default(now())
  
  @@index([ecoId])
  @@index([ruleId])
}

// ========== PASSWORD RESET SYSTEM ==========

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Token stored as bcrypt hash (not plaintext)
  token     String    @unique
  
  // Security fields
  expiresAt DateTime
  usedAt    DateTime?  // NULL = unused, SET = used once
  createdAt DateTime   @default(now())
  
  @@index([userId])
  @@index([expiresAt])
}
